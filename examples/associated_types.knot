-- Associated types: type-level functions defined per impl.
-- `Elem c` is computed from the container type at each instance.

trait Container c where
  type Elem c
  size : c -> Int 1
  toList : c -> [Elem c]

impl Container [a] where
  type Elem [a] = a
  size xs = count xs
  toList xs = xs

nums : [Int 1]
nums = [1, 2, 3]

words : [Text]
words = ["alpha", "beta", "gamma"]

main = do
  println (size nums)
  println (toList nums)
  println (size words)
  println (toList words)
  yield {}
