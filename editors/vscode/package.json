{
  "name": "knot-lang",
  "displayName": "Knot",
  "description": "Language support for the Knot programming language",
  "version": "0.1.0",
  "publisher": "knot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/knot-lang/knot"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:knot"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "knot",
        "aliases": [
          "Knot",
          "knot"
        ],
        "extensions": [
          ".knot"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        },
        "filenames": [
          "*.knot"
        ]
      }
    ],
    "grammars": [
      {
        "language": "knot",
        "scopeName": "source.knot",
        "path": "./syntaxes/knot.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Knot",
      "properties": {
        "knot.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to the knot-lsp binary. If empty, searches PATH and cargo target directory."
        },
        "knot.server.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments to pass to knot-lsp."
        },
        "knot.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Knot language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
