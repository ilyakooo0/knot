-- Test forEach builtin.

main = do
  -- Basic case: print each integer
  forEach [1, 2, 3] (\x -> println (show x))
  -- Empty list: action shouldn't run
  forEach [] (\x -> println (show x))
  -- Strings
  forEach ["a", "b", "c"] (\s -> println s)
  -- After forEach: subsequent actions still run
  println "done"
  yield {}
