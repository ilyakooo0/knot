-- ── Main ─────────────────────────────────────────────────────────

main = do
  seedEmployees
  seedProjects
  seedTickets
  seedCustomers
  seedProducts
  seedOrders
  seedTeams
  seedLogs
  seedMetrics
  yield (show (count *employees) ++ " employees, "
    ++ show (count *projects) ++ " projects, "
    ++ show (count *tickets) ++ " tickets, "
    ++ show (count *customers) ++ " customers, "
    ++ show (count *products) ++ " products, "
    ++ show (count *orders) ++ " orders, "
    ++ show (count *teams) ++ " teams, "
    ++ show (count *logs) ++ " logs, "
    ++ show (count *metrics) ++ " metrics")
