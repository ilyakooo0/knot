{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(do|where|of|then|else|let|impl|trait|data|route|migrate)\\b|.*=\\s*$|.*->\\s*$",
    "decreaseIndentPattern": "^\\s*(else|of)\\b"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_']*"
}
